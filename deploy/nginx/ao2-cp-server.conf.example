# Nginx reverse-proxy template for ao2-control-plane v0.1+.
#
# ao2-cp-server intentionally has no native TLS — it binds 127.0.0.1
# and relies on a reverse proxy for TLS termination, rate limiting,
# and access control.
#
# Install:
#   1. Save this file as
#      /etc/nginx/conf.d/ao2-cp-server.conf (or
#      /etc/nginx/sites-available/ao2-cp-server, then symlink).
#   2. Replace every `ao2-cp.example.com` with your DNS name.
#   3. Replace the cert/key paths with your real certificate.
#      For Let's Encrypt + certbot, the canonical paths are
#      /etc/letsencrypt/live/<name>/{fullchain,privkey}.pem.
#   4. Ensure ao2-cp-server is listening on 127.0.0.1:8744 (see
#      deploy/linux/ao2-cp-server.service).
#   5. `sudo nginx -t && sudo systemctl reload nginx`
#
# Trust posture: this proxy template only terminates TLS, rate-limits
# inbound requests, and forwards to the local observer. It does not
# inspect bodies, rewrite paths, or cache responses.

# Rate-limit zones. The control-plane's /healthz endpoint is unauthenticated
# and trivially cheap to serve; we allow more bursts there than on /api/v1/*.
# Adjust burst sizes if you have legitimate burst publishers. The AO2 CLI's
# default backoff tolerates 429s.
limit_req_zone $binary_remote_addr zone=ao2cp_api:10m rate=120r/m;
limit_req_zone $binary_remote_addr zone=ao2cp_healthz:10m rate=600r/m;

# Cap concurrent connections per IP (defense against slow-loris and
# accidental fan-out from a single misconfigured client).
limit_conn_zone $binary_remote_addr zone=ao2cp_conn:10m;

server {
    listen 80;
    listen [::]:80;
    server_name ao2-cp.example.com;

    # Redirect all HTTP to HTTPS.
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name ao2-cp.example.com;

    ssl_certificate     /etc/letsencrypt/live/ao2-cp.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/ao2-cp.example.com/privkey.pem;

    # Modern profile (Mozilla intermediate, 2026). Drop TLSv1.2 once
    # all clients are 1.3-capable.
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_session_timeout 1d;
    ssl_session_cache shared:MozSSL:10m;
    ssl_session_tickets off;

    # HSTS (1 year). Only enable after the cert is stable in
    # production — accidentally serving an expired cert with HSTS
    # active locks clients out.
    add_header Strict-Transport-Security "max-age=31536000" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "no-referrer" always;

    # Per-connection cap. Burst absorbs short spikes; nodelay rejects
    # anything beyond burst rather than queuing it.
    limit_conn ao2cp_conn 16;

    # Hide identifying server token.
    server_tokens off;

    # Defense-in-depth: strip any provider-key-shaped headers that an
    # accidentally misconfigured client may forward. The server-side
    # preflight already refuses to start with these in its env; this
    # prevents a header→env leak path through misbehaving middleware.
    proxy_set_header OPENAI_API_KEY "";
    proxy_set_header ANTHROPIC_API_KEY "";

    # Healthz: cheap, unauthenticated, higher allowance.
    location = /healthz {
        limit_req zone=ao2cp_healthz burst=20 nodelay;
        proxy_pass http://127.0.0.1:8744/healthz;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # API: authenticated; bearer-token middleware in the server enforces
    # auth, we rate-limit at the edge as defense-in-depth.
    location / {
        limit_req zone=ao2cp_api burst=20 nodelay;

        proxy_pass http://127.0.0.1:8744;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";

        # The control plane streams support-bundle JSON responses;
        # allow up to a few minutes for large bundle fetches.
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;

        # Cap upload size to match the server's default
        # AO2_CP_MAX_BODY_BYTES (10 MiB). Raise here if the server is
        # configured with a higher limit.
        client_max_body_size 10m;
    }

    # Access log includes the rate-limit decision (req_status field is
    # 200/429/etc.). Rotate via logrotate.d/nginx.
    access_log /var/log/nginx/ao2-cp.access.log;
    error_log  /var/log/nginx/ao2-cp.error.log warn;
}
