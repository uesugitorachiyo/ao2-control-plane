# /etc/ao2-cp-server.env
# Mode: 0600 root:root (or 0640 root:ao2cp). Do NOT commit a filled copy.
# Generate AO2_CP_API_TOKEN with `openssl rand -hex 32` before first boot.

AO2_CP_API_TOKEN=REPLACE_WITH_A_FRESH_RANDOM_TOKEN
AO2_CP_LOG_LEVEL=info

# Optional overrides:
# AO2_CP_BIND=127.0.0.1:8744
# AO2_CP_DATA_DIR=/var/lib/ao2-cp-server/data
# AO2_CP_MAX_BODY_BYTES=10485760

# Forbidden — server refuses to start if either is present:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
